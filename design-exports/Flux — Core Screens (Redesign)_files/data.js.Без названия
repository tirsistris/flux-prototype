// data.js — single source of truth for Flux. EUR everywhere, European number format.
// Thousands separator = space, decimal = comma. Crypto-only.

function fmtNum(n, dec = 2) {
  const neg = n < 0;
  const fixed = Math.abs(n).toFixed(dec);
  let [int, frac] = fixed.split('.');
  int = int.replace(/\B(?=(\d{3})+(?!\d))/g, '\u00A0'); // thousands = space
  return (neg ? '-' : '') + int + (dec ? ',' + frac : '');
}
const eur = (n, dec = 2) => fmtNum(n, dec) + '\u202F\u20AC';
const pct = (n, dec = 2) => (n >= 0 ? '+' : '') + fmtNum(n, dec) + '\u202F%';
const signEur = (n, dec = 2) => (n >= 0 ? '+' : '') + fmtNum(n, dec) + '\u202F\u20AC';

